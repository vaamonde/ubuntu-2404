#!/bin/bash

# =========================
# SYSTEM INFORMATION
# =========================
HOST=$(hostname)
IP=$(hostname -I | awk '{print $1}')
KERNEL=$(uname -r)
UPTIME=$(uptime -p)

# =========================
# RESOURCE USAGE
# =========================
CPU=$(top -bn1 | grep "Cpu(s)" | awk '{print $2 + $4}')
MEM=$(free -h | awk '/Mem:/ {print $3 "/" $2}')
DISK=$(df -h / | awk 'NR==2 {print $3 "/" $2 " (" $5 ")"}')

# =========================
# DOCKER INFO
# =========================
DOCKER=$(docker ps -q 2>/dev/null | wc -l)

# =========================
# OUTPUT
# =========================

